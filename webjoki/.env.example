# Environment Variables untuk Vercel Deployment

# Database (Vercel Postgres / Neon)
# Vercel biasanya mengisi POSTGRES_URL atau DATABASE_URL otomatis saat database di-link ke project.
POSTGRES_URL=postgres://username:password@host.neon.tech/dbname?sslmode=require
# DATABASE_URL=postgres://username:password@host.neon.tech/dbname?sslmode=require
# POSTGRES_URL_NON_POOLING=postgres://username:password@host.neon.tech/dbname?sslmode=require

# JWT Secret untuk token authentication. Wajib diisi di Vercel, jangan pakai contoh ini di production.
JWT_SECRET=change-this-to-a-long-random-secret

# App URL (optional, untuk production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
